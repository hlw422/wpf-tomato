<UserControl x:Class="Wpf_Tomato.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Wpf_Tomato.Converters">
    
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisInvert" Invert="True"/>
        
        <!-- 日历日期按钮样式 -->
        <Style x:Key="CalendarDayButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#f0f0f0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e0e0e0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 月份导航 -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Margin="15,10,15,8" Padding="12"
                BorderBrush="#eee" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="◀ 上月" Command="{Binding PreviousMonthCommand}"
                        Style="{StaticResource ControlButton}" Padding="12,8" Margin="0,0,10,0"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentMonthDisplay}" FontSize="20" FontWeight="Bold"
                               Foreground="#333" VerticalAlignment="Center"/>
                    <Button Content="今天" Command="{Binding GoToTodayCommand}"
                            Style="{StaticResource ControlButton}" Padding="10,6" Margin="15,0,0,0"/>
                </StackPanel>
                
                <Button Grid.Column="2" Content="下月 ▶" Command="{Binding NextMonthCommand}"
                        Style="{StaticResource ControlButton}" Padding="12,8" Margin="10,0,0,0"/>
            </Grid>
        </Border>
        
        <!-- 搜索栏 -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Margin="15,0,15,8" Padding="10"
                BorderBrush="#eee" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#f8f8f8" BorderBrush="#eee" BorderThickness="1"
                         Padding="10,8" FontSize="13" Foreground="#333"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Tag">
                                        <Setter.Value>
                                            <TextBlock Text="搜索记事和待办事项..." Foreground="#bbb"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding PerformSearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                
                <Button Grid.Column="1" Content="🔍 搜索" Command="{Binding PerformSearchCommand}"
                        Style="{StaticResource AccentButton}" Padding="12,8" Margin="8,0,0,0"/>
                
                <Button Grid.Column="2" Content="清除" Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource ControlButton}" Padding="10,8" Margin="4,0,0,0"
                        Visibility="{Binding ShowSearchResults, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
        
        <!-- 搜索结果 -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Margin="15,0,15,8" Padding="10"
                BorderBrush="#eee" BorderThickness="1"
                Visibility="{Binding ShowSearchResults, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="🔍 搜索结果" FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                    <TextBlock Text="{Binding SearchResults.Count, StringFormat=' ({0} 条)'}" 
                               FontSize="14" Foreground="#666" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <ItemsControl ItemsSource="{Binding SearchResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.GoToSearchResultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                        Padding="0" Margin="0,2">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="#f8f8f8" CornerRadius="6" Padding="10,8"
                                                    BorderBrush="#eee" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding TypeIcon}" FontSize="14" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Type}" FontSize="12" Foreground="#666" 
                                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Grid.Column="1" Text="{Binding MatchText}" FontSize="13" 
                                                               Foreground="#333" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    
                                                    <TextBlock Grid.Column="2" Text="{Binding DateDisplay}" FontSize="12" 
                                                               Foreground="#999" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#e8e8e8"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#d8d8d8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <!-- 日历网格 -->
        <Border Grid.Row="3" Background="White" CornerRadius="10" Margin="15,0,15,8" Padding="10"
                BorderBrush="#eee" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 星期标题 -->
                <UniformGrid Grid.Row="0" Rows="1" Columns="7" Margin="0,0,0,4">
                    <TextBlock Text="一" HorizontalAlignment="Center" Foreground="#999" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="二" HorizontalAlignment="Center" Foreground="#999" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="三" HorizontalAlignment="Center" Foreground="#999" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="四" HorizontalAlignment="Center" Foreground="#999" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="五" HorizontalAlignment="Center" Foreground="#999" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="六" HorizontalAlignment="Center" Foreground="#FF8C00" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="日" HorizontalAlignment="Center" Foreground="#FF8C00" FontSize="13" FontWeight="SemiBold"/>
                </UniformGrid>
                
                <!-- 日期网格 -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding CalendarDays}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="6" Columns="7"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectDateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource CalendarDayButton}"
                                    ToolTip="{Binding ToolTipText}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" CornerRadius="8" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <!-- 今日且选中：橙色背景 -->
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsToday}" Value="True"/>
                                                                <Condition Binding="{Binding IsSelected}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="#FF8C00"/>
                                                        </MultiDataTrigger>
                                                        <!-- 今日未选中：淡橙色背景 -->
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                            <Setter Property="BorderBrush" Value="#FF8C00"/>
                                                        </DataTrigger>
                                                        <!-- 非今日但选中：深灰色背景 -->
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#333"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <!-- 有记事的小点（底层） -->
                                                <Ellipse Width="6" Height="6" Fill="#FF8C00" 
                                                         HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                         Margin="0,0,0,4"
                                                         Visibility="{Binding HasNote, Converter={StaticResource BoolToVis}}"/>
                                                
                                                <!-- 日期文字（顶层） -->
                                                <TextBlock Text="{Binding DayNumberText}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="13" FontWeight="Normal">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                    <Setter Property="Foreground" Value="#ccc"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="True">
                                                                    <Setter Property="Foreground" Value="#333"/>
                                                                </DataTrigger>
                                                                <!-- 今日且选中：白色粗体 -->
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsToday}" Value="True"/>
                                                                        <Condition Binding="{Binding IsSelected}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                </MultiDataTrigger>
                                                                <!-- 今日未选中：橙色粗体 -->
                                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FF8C00"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                </DataTrigger>
                                                                <!-- 非今日但选中：白色粗体 -->
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#f5f5f5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
        
        <!-- 记事编辑区域 -->
        <Border Grid.Row="4" Background="White" CornerRadius="10" Margin="15,0,15,10" Padding="10"
                BorderBrush="#eee" BorderThickness="1"
                Visibility="{Binding IsEditingAndNotSearching, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 标题 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="📝 " FontSize="16"/>
                        <TextBlock Text="{Binding SelectedDate, StringFormat='{}{0:yyyy年MM月dd日} 记事'}"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#333"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="1" Text="{Binding CurrentNote.LastModified, StringFormat='{}最后编辑: {0:HH:mm}'}"
                               Foreground="#999" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
                
                <!-- 内容输入 -->
                <TextBox Grid.Row="1" Text="{Binding CurrentNote.Content, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Background="#f8f8f8" BorderBrush="#eee" BorderThickness="1"
                         Padding="12" FontSize="14" Foreground="#333"
                         Height="100" Margin="0,0,0,10">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Tag">
                                        <Setter.Value>
                                            <TextBlock Text="记录今天的待办事项、日常记录或灵感笔记..." Foreground="#bbb"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                
                <!-- 待办事项 -->
                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="📋 待办事项" FontSize="14" FontWeight="SemiBold"
                               Foreground="#555" Margin="0,0,0,8"/>
                    
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CurrentNote.Todos}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#f8f8f8" CornerRadius="5" Padding="10,6" Margin="0,2"
                                        BorderBrush="#eee" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="&#x2611;" Foreground="#FF8C00" 
                                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#333"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                        
                                        <Button Grid.Column="2" Content="&#x2716;" 
                                                Command="{Binding DataContext.RemoveTodoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#cc3333" BorderThickness="0"
                                                FontSize="12" Width="20" Height="20" Cursor="Hand"
                                                ToolTip="删除此待办"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
                
                <!-- 添加待办 -->
                <Grid Grid.Row="3" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" Text="{Binding NewTodoText, UpdateSourceTrigger=PropertyChanged}"
                             Background="#f8f8f8" BorderBrush="#eee" BorderThickness="1"
                             Padding="10,8" FontSize="13" Foreground="#333"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Tag">
                                            <Setter.Value>
                                                <TextBlock Text="添加新的待办事项..." Foreground="#bbb"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    
                    <Button Grid.Column="1" Content="添加" Command="{Binding AddTodoCommand}"
                            Style="{StaticResource AccentButton}" Padding="15,8" Margin="10,0,0,0"/>
                </Grid>
                
                <!-- 操作按钮 -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Command="{Binding CancelEditCommand}"
                            Style="{StaticResource ControlButton}" Padding="20,10" Margin="0,0,10,0"/>
                    <Button Content="💾 保存" Command="{Binding SaveNoteCommand}"
                            Style="{StaticResource AccentButton}" Padding="20,10"/>
                </StackPanel>
            </Grid>
            </ScrollViewer>
        </Border>
        
        <!-- 未选择日期时的提示 -->
        <Border Grid.Row="4" Background="White" CornerRadius="10" Margin="15,0,15,10" Padding="20"
                BorderBrush="#eee" BorderThickness="1"
                Visibility="{Binding IsEditingAndNotSearching, Converter={StaticResource BoolToVisInvert}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="点击日历中的日期" FontSize="16" Foreground="#666"
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="查看或编辑当日的记事" FontSize="14" Foreground="#999"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
