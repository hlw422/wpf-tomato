<Window x:Class="Wpf_Tomato.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_Tomato"
        xmlns:converters="clr-namespace:Wpf_Tomato.Converters"
        mc:Ignorable="d"
        Title="番茄时钟" Height="660" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#f5f5f5">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisInvert" Invert="True"/>
        <converters:ProgressOffsetConverter x:Key="ProgressOffset"/>

        <!-- Control Button Style -->
        <Style x:Key="ControlButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#ddd"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#f0f0f0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#bbb"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e8e8e8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ControlButton}">
            <Setter Property="Background" Value="#FF8C00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#E07000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFA040"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E07000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleButton" TargetType="Button" BasedOn="{StaticResource ControlButton}">
            <Setter Property="Background" Value="#666"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#888"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="SettingTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox Style -->
        <Style x:Key="SettingCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Navigation -->
        <Border Grid.Row="0" Background="White" Padding="10,8" BorderBrush="#eee" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,20,0">
                    <TextBlock Text="&#x1F345;" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="番茄时钟" FontSize="16" FontWeight="SemiBold" Foreground="#333"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="&#x23F1; 计时器" Style="{StaticResource ControlButton}" Padding="15,8" Margin="0,0,5,0"
                            Click="TimerTab_Click" x:Name="TimerTab"/>
                    <Button Content="&#x1F4CA; 统计" Style="{StaticResource ControlButton}" Padding="15,8" Margin="0,0,5,0"
                            Click="StatsTab_Click" x:Name="StatsTab"/>
                    <Button Content="&#x2699; 设置" Style="{StaticResource ControlButton}" Padding="15,8"
                            Click="SettingsTab_Click" x:Name="SettingsTab"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Timer View -->
        <Grid Grid.Row="1" x:Name="TimerView">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Mode Indicator -->
            <Border Grid.Row="0" Margin="0,15,0,0" HorizontalAlignment="Center"
                    CornerRadius="15" Padding="20,8" Background="{Binding ModeColor}">
                <TextBlock Text="{Binding ModeDisplay}" FontSize="16" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center"/>
            </Border>

            <!-- Timer Circle -->
            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                  Width="260" Height="260" Margin="0,5">
                <!-- Outer ring background -->
                <Ellipse Stroke="#e0e0e0" StrokeThickness="8" Fill="Transparent"/>

                <!-- Progress ring -->
                <Ellipse Stroke="{Binding ModeColor}" StrokeThickness="8" Fill="Transparent"
                         StrokeDashArray="753.98" StrokeDashOffset="{Binding Progress, Converter={StaticResource ProgressOffset}}"
                         StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Inner circle -->
                <Ellipse Fill="White" Stroke="#eee" StrokeThickness="1" Width="220" Height="220"/>

                <!-- Time Display -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TimeDisplay}" FontSize="64" FontWeight="Bold"
                               Foreground="#FF8C00" HorizontalAlignment="Center"
                               FontFamily="Consolas, monospace"/>
                    <TextBlock Text="{Binding StatusDisplay}" FontSize="14"
                               Foreground="#E07000" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Cycle Progress -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                <TextBlock Text="番茄进度:" Foreground="#999" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding CycleProgress}" Foreground="#333" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="  |  今日:" Foreground="#999" FontSize="13" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <TextBlock Text="{Binding TodayPomodoros}" Foreground="#555" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="个" Foreground="#999" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Task Input -->
            <Border Grid.Row="3" Margin="40,5,40,5" CornerRadius="8" Background="White"
                    BorderBrush="#ddd" BorderThickness="1" Padding="12,8">
                <TextBox Text="{Binding TaskContent, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent" BorderThickness="0" FontSize="14"
                         Foreground="#333" VerticalContentAlignment="Center"
                         x:Name="TaskInput">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Tag">
                                        <Setter.Value>
                                            <TextBlock Text="输入当前任务内容..." Foreground="#bbb"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>

            <!-- Control Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20,5,20,5">
                <Button Content="&#x25B6; 开始" Style="{StaticResource AccentButton}"
                        Command="{Binding StartCommand}"
                        x:Name="StartButton" Padding="20,12" Margin="0,0,8,0"
                        Visibility="{Binding IsPauseEnabled, Converter={StaticResource BoolToVisInvert}}"/>
                <Button Content="&#x23F8; 暂停" Style="{StaticResource AccentButton}"
                        Command="{Binding PauseCommand}"
                        Padding="20,12" Margin="0,0,8,0"
                        Visibility="{Binding IsPauseEnabled, Converter={StaticResource BoolToVis}}"/>

                <Button Content="&#x21BA; 重置" Style="{StaticResource ControlButton}"
                        Command="{Binding ResetCommand}"
                        Padding="20,12" Margin="0,0,8,0"/>

                <Button Content="&#x23ED; 跳过" Style="{StaticResource ToggleButton}"
                        Command="{Binding SkipCommand}"
                        Padding="20,12" Margin="0"/>
            </StackPanel>

            <!-- Hotkey Info -->
            <TextBlock Grid.Row="5" Text="Ctrl+Alt+T 暂停 | Ctrl+Alt+R 重置 | Ctrl+Alt+S 跳过"
                       Foreground="#bbb" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,10"/>
        </Grid>

        <!-- Statistics View -->
        <Grid Grid.Row="1" x:Name="StatsView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Today Summary -->
            <Border Grid.Row="0" Background="White" CornerRadius="10" Margin="15,15,15,10" Padding="15"
                    BorderBrush="#eee" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="今日完成" Foreground="#999" FontSize="12" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TodayPomodoros}" FontSize="36" FontWeight="Bold"
                                       Foreground="#FF8C00"/>
                            <TextBlock Text=" 个" Foreground="#888" FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="专注时长" Foreground="#999" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TodayFocusTime}" FontSize="36" FontWeight="Bold"
                                   Foreground="#555" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- History List -->
            <Border Grid.Row="1" Background="White" CornerRadius="10" Margin="15,0,15,15" Padding="10"
                    BorderBrush="#eee" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,10">
                        <TextBlock Text="&#x1F4C5; 最近记录" Foreground="#333" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <ListView Grid.Row="1" ItemsSource="{Binding DailyStats}" Background="Transparent"
                              BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#f8f8f8" CornerRadius="6" Padding="12,8" Margin="0,2"
                                        BorderBrush="#eee" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat='{}{0:MM月dd日}'}"
                                                   Foreground="#444" FontSize="13" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,15,0">
                                            <TextBlock Text="&#x1F345; " FontSize="13"/>
                                            <TextBlock Text="{Binding CompletedPomodoros}" Foreground="#333"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <TextBlock Text="&#x23F1; " FontSize="13"/>
                                            <TextBlock Text="{Binding TotalFocusMinutes, StringFormat='{}{0}分钟'}"
                                                       Foreground="#666" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Settings View -->
        <ScrollViewer Grid.Row="1" x:Name="SettingsView" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,15">
                <TextBlock Text="&#x23F0; 时间设置" Foreground="#333" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="专注时长 (分钟)" Foreground="#666" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding FocusDuration}" Style="{StaticResource SettingTextBox}"
                             HorizontalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="短休息时长 (分钟)" Foreground="#666" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding ShortBreakDuration}" Style="{StaticResource SettingTextBox}"
                             HorizontalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="长休息时长 (分钟)" Foreground="#666" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding LongBreakDuration}" Style="{StaticResource SettingTextBox}"
                             HorizontalContentAlignment="Center"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="长休息间隔 (番茄数)" Foreground="#666" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding LongBreakInterval}" Style="{StaticResource SettingTextBox}"
                             HorizontalContentAlignment="Center"/>
                </Grid>

                <Separator Background="#eee" Margin="0,15"/>

                <TextBlock Text="&#x2699; 行为设置" Foreground="#333" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <CheckBox Content="自动开始休息" IsChecked="{Binding AutoStartBreaks}"
                          Style="{StaticResource SettingCheckBox}"/>
                <CheckBox Content="自动开始专注" IsChecked="{Binding AutoStartPomodoros}"
                          Style="{StaticResource SettingCheckBox}"/>
                <CheckBox Content="最小化到系统托盘" IsChecked="{Binding MinimizeToTray}"
                          Style="{StaticResource SettingCheckBox}"/>
                <CheckBox Content="播放提示音" IsChecked="{Binding PlaySound}"
                          Style="{StaticResource SettingCheckBox}"/>
                <CheckBox Content="显示桌面通知" IsChecked="{Binding ShowNotification}"
                          Style="{StaticResource SettingCheckBox}"/>

                <Button Content="&#x2714; 保存设置" Style="{StaticResource AccentButton}"
                        Command="{Binding ApplySettingsCommand}" Margin="0,20,0,0"
                        HorizontalAlignment="Stretch" Padding="15"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
